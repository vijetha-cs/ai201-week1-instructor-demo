# AI 201 Week 1 Demo — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────

# Your OpenRouter API key.
# Sign up free at: https://openrouter.ai
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────

# OpenRouter model to use for answering queries.
# Default: meta-llama/llama-3.1-8b-instruct:free (free, no credits needed)
# Other good free options:
#   google/gemma-2-9b-it:free
#   mistralai/mistral-7b-instruct:free
# Full list: https://openrouter.ai/models?q=free
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
