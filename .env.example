# AI 201 Week 1 Demo — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────

# Your OpenRouter API key.
# Sign up free at: https://openrouter.ai
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────

# OpenRouter model to use for answering queries.
# Default: openai/gpt-oss-20b:free (free, no credits needed)
# Other good free options:
#   google/gemma-4-31b-it:free
#   deepseek/deepseek-v4-flash:free
#   z-ai/glm-4.5-air:free
# Avoid Meta Llama :free variants — they route through Venice and are
# frequently rate-limited (HTTP 429). Full list: https://openrouter.ai/models?q=free
#
# If you hit repeated 429s on every :free model, top up $5 of OpenRouter credit
# and drop the :free suffix — a full demo run costs < $0.01 and removes the
# rate-limit cliff entirely.
# OPENROUTER_MODEL=openai/gpt-oss-20b:free
